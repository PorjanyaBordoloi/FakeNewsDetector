{
    "manifest_version": 3,
    "name": "Fake News Detector",
    "version": "1.0.0",
    "description": "AI-Powered Misinformation Detection — Quick fake/real verdict while browsing.",
    "permissions": [
        "activeTab",
        "storage"
    ],
    "action": {
        "default_popup": "popup.html"
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ]
        }
    ]
}